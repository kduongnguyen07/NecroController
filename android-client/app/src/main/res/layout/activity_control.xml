<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nero_bg">

    <!-- ĐÃ TĂNG ĐỘ SÁNG ẢNH LÊN 0.8 -->
    <ImageView
        android:id="@+id/img_control_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.8" />

    <!-- ĐÃ GIẢM KÍNH ĐEN XUỐNG #99121212 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99121212" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <!-- HEADER -->
            <TextView
                android:id="@+id/tv_device_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/nero_purple"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:text="Tên máy tính" />

            <TextView
                android:id="@+id/tv_device_ip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/nero_text_dim"
                android:textSize="14sp"
                android:layout_marginBottom="24dp"
                android:text="192.168.x.x" />

            <!-- VOLUME CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/nero_surface"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:strokeColor="#33BB86FC"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tv_vol_preview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ÂM LƯỢNG MÁY TÍNH: 50%"
                        android:textColor="@color/nero_purple"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <SeekBar
                        android:id="@+id/sb_volume"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="50"
                        android:progressTint="@color/nero_purple"
                        android:thumbTint="@color/nero_teal" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- POWER & SYSTEM CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/nero_surface"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:strokeColor="#3303DAC5"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NGUỒN &amp; HỆ THỐNG"
                        android:textColor="@color/nero_teal"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- Row 1: Off, Lock, Sleep -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="3"
                        android:layout_marginBottom="10dp">

                        <LinearLayout android:id="@+id/btn_off"
                            android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center"
                            android:background="@drawable/btn_neon_purple" android:layout_marginEnd="6dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_power"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Tắt máy" android:textColor="@color/nero_text" android:textSize="11sp" android:layout_marginTop="6dp"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btn_lock"
                            android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center"
                            android:background="@drawable/btn_neon_purple" android:layout_marginEnd="3dp" android:layout_marginStart="3dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_lock"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Khóa" android:textColor="@color/nero_text" android:textSize="11sp" android:layout_marginTop="6dp"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btn_sleep"
                            android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center"
                            android:background="@drawable/btn_neon_purple" android:layout_marginStart="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🌙" android:textSize="24sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Ngủ" android:textColor="@color/nero_text" android:textSize="11sp" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Row 2: Restart, Timer, Abort -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <LinearLayout android:id="@+id/btn_wake"
                            android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1"
                            android:orientation="horizontal" android:gravity="center"
                            android:background="@drawable/btn_neon_teal" android:layout_marginEnd="6dp">
                            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                                android:src="@drawable/ic_restart" android:layout_marginEnd="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="RESTART" android:textColor="@color/nero_teal" android:textSize="12sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btn_timer"
                            android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1"
                            android:orientation="horizontal" android:gravity="center"
                            android:background="@drawable/btn_neon_purple" android:layout_marginEnd="3dp" android:layout_marginStart="3dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="⏱ HẸN GIỜ" android:textColor="@color/nero_purple" android:textSize="11sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btn_abort"
                            android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1"
                            android:orientation="horizontal" android:gravity="center"
                            android:background="@drawable/btn_neon_purple" android:layout_marginStart="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="❌ HỦY" android:textColor="#F44336" android:textSize="11sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ADVANCED TOOLS CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/nero_surface"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:strokeColor="#33BB86FC"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CÔNG CỤ NÂNG CAO"
                        android:textColor="@color/nero_purple"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- Row: Webcam + Screenshot -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="10dp">

                        <LinearLayout android:id="@+id/btn_stealth_webcam"
                            android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center"
                            android:background="@drawable/btn_neon_purple" android:layout_marginEnd="5dp">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_camera_stealth"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="WEBCAM" android:textColor="@color/nero_purple" android:textSize="11sp"
                                android:textStyle="bold" android:layout_marginTop="6dp"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btn_screenshot"
                            android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center"
                            android:background="@drawable/btn_neon_teal" android:layout_marginStart="5dp">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_screenshot"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="SCREENSHOT" android:textColor="@color/nero_teal" android:textSize="11sp"
                                android:textStyle="bold" android:layout_marginTop="6dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Row: Shell + Monitor -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="10dp">

                        <LinearLayout android:id="@+id/btn_shell"
                            android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center"
                            android:background="@drawable/btn_neon_purple" android:layout_marginEnd="5dp">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_terminal"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="SHELL CMD" android:textColor="@color/nero_purple" android:textSize="11sp"
                                android:textStyle="bold" android:layout_marginTop="6dp"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btn_open_monitor"
                            android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center"
                            android:background="@drawable/btn_neon_teal" android:layout_marginStart="5dp">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_monitor"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="TASK MGR" android:textColor="@color/nero_teal" android:textSize="11sp"
                                android:textStyle="bold" android:layout_marginTop="6dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Row: File Search + File Download -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <LinearLayout android:id="@+id/btn_file_search"
                            android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center"
                            android:background="@drawable/btn_neon_purple" android:layout_marginEnd="5dp">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_search"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="TÌM FILE" android:textColor="@color/nero_purple" android:textSize="11sp"
                                android:textStyle="bold" android:layout_marginTop="6dp"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btn_file_download"
                            android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center"
                            android:background="@drawable/btn_neon_teal" android:layout_marginStart="5dp">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_file_download"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="TẢI FILE" android:textColor="@color/nero_teal" android:textSize="11sp"
                                android:textStyle="bold" android:layout_marginTop="6dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- GOD MODE: VOICE + CLIPBOARD + LIVE STREAM -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/nero_surface"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:strokeColor="#3303DAC5"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="☠ GOD MODE"
                        android:textColor="@color/nero_teal"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- Row: Voice + Clipboard -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="10dp">

                        <LinearLayout android:id="@+id/btn_voice_control"
                            android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center"
                            android:background="@drawable/btn_neon_purple" android:layout_marginEnd="5dp">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_mic"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="VOICE CMD" android:textColor="@color/nero_purple" android:textSize="11sp"
                                android:textStyle="bold" android:layout_marginTop="6dp"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btn_clipboard_sync"
                            android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center"
                            android:background="@drawable/btn_neon_teal" android:layout_marginStart="5dp">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_content_copy"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="CLIPBOARD" android:textColor="@color/nero_teal" android:textSize="11sp"
                                android:textStyle="bold" android:layout_marginTop="6dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Row: Live Stream -->
                    <LinearLayout android:id="@+id/btn_live_stream"
                        android:layout_width="match_parent" android:layout_height="60dp"
                        android:orientation="horizontal" android:gravity="center"
                        android:background="@drawable/btn_neon_teal">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp"
                            android:src="@drawable/ic_live_stream" android:layout_marginEnd="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔴 LIVE STREAM MÀN HÌNH" android:textColor="@color/nero_teal" android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Spacer -->
            <View android:layout_width="1dp" android:layout_height="30dp"/>

        </LinearLayout>
    </ScrollView>
</FrameLayout>